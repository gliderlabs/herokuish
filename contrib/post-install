#!/usr/bin/env bash

if which systemctl >/dev/null; then
  echo "Starting docker"
  systemctl start docker
  sleep 5
fi

echo "Pruning dangling images"
docker images -qf dangling=true | xargs --no-run-if-empty docker rmi

echo "Pruning unused gliderlabs/herokuish images"
docker images -a --format table | grep "^gliderlabs\/herokuish" | grep -v latest | awk '{print $3}' | xargs --no-run-if-empty docker rmi || true

echo 'Importing herokuish into docker (around 5 minutes)'
if [[ -n "$http_proxy" ]] || [[ -n "$https_proxy" ]]; then
  echo "See the docker pull docs for proxy configuration"
fi

VERSION=$(cat /var/lib/herokuish/VERSION)
IMAGE="gliderlabs/herokuish:v${VERSION}-24"

attempt=1
max_attempts=5
delay=10
while true; do
  if sudo docker pull "$IMAGE"; then
    break
  fi
  if [[ $attempt -ge $max_attempts ]]; then
    echo "Failed to pull $IMAGE after $max_attempts attempts." >&2
    echo "Run 'sudo docker pull $IMAGE && sudo docker tag $IMAGE gliderlabs/herokuish:latest-24' once connectivity returns." >&2
    exit 1
  fi
  echo "docker pull failed; retrying in ${delay}s (attempt ${attempt}/${max_attempts})" >&2
  sleep "$delay"
  attempt=$((attempt + 1))
  delay=$((delay * 2))
done

sudo docker tag "$IMAGE" gliderlabs/herokuish:latest-24
